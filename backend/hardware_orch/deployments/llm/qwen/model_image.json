{
  "slug": "qwen",
  "name": "Qwen",
  "family": "llm",
  "image": "sabhuku/llm-qwen:local",
  "context": ".",
  "dockerfile": "qwen/Dockerfile",
  "internal_port": 8000,
  "health_path": "/health",
  "description": "Qwen Hugging Face causal language model image.",
  "env": {
    "LLM_MODEL_NAME": "qwen",
    "LLM_MODEL_ID": "Qwen/Qwen2.5-1.5B-Instruct",
    "LLM_DEVICE": "auto",
    "LLM_DTYPE": "auto",
    "LLM_TRUST_REMOTE_CODE": "true",
    "HF_HOME": "/models/huggingface",
    "TRANSFORMERS_CACHE": "/models/huggingface"
  },
  "endpoints": [
    {
      "name": "generate",
      "method": "POST",
      "public_path": "/generate",
      "upstream_path": "/generate"
    },
    {
      "name": "chat_completions",
      "method": "POST",
      "public_path": "/v1/chat/completions",
      "upstream_path": "/v1/chat/completions"
    }
  ]
}
